# Foundry (packages/foundry)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0x...
ETHERSCAN_API_KEY=

# Optional: override USDC address (defaults to Circle Sepolia USDC)
# SEPOLIA_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Next.js (packages/nextjs)
NEXT_PUBLIC_ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=YOUR_WC_PROJECT_ID
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side only — never prefix with NEXT_PUBLIC_
OPENROUTER_API_KEY=sk-or-...
